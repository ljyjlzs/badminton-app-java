# 数据库配置
DB_ROOT_PASSWORD=root123456
DB_USERNAME=badminton
DB_PASSWORD=badminton123456
DB_PORT=3306

# 应用配置
APP_PORT=8049
SPRING_PROFILES_ACTIVE=prod

# 微信小程序配置（必填）
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# JWT 配置（必填，至少 32 位）
JWT_SECRET=your_jwt_secret_at_least_32_chars!
JWT_EXPIRATION=604800000

# AI 服务配置（可选）
AI_API_KEY=your_ai_key
AI_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions

# JVM 配置（可选）
JAVA_OPTS=-Xms256m -Xmx512m
