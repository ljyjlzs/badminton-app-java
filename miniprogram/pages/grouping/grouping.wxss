.grouping-page {
  min-height: 100vh;
}

.grouping-loading {
  min-height: 100vh;
}

.grouping-shell {
  padding-top: 18rpx;
}

.grouping-hero {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #103c31 0%, #17513f 56%, #1c6d57 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(16, 60, 49, 0.22);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.86);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.hero-stat-card {
  min-width: 168rpx;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.stat-num {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #ffffff;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.grouping-section {
  background: rgba(255, 255, 255, 0.96);
  padding: 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  box-shadow: var(--shadow-card);
}

.start-all-section {
  margin-bottom: 24rpx;
}

.btn-start-all {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #536ff3 0%, #6b53c5 100%);
  color: #ffffff;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 12rpx 24rpx rgba(83, 111, 243, 0.2);
}

.btn-icon {
  font-size: 30rpx;
  line-height: 1;
}

.progress-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff6e8 0%, #ffecc4 100%);
  color: #cc8615;
  margin-bottom: 24rpx;
}

.hint-icon {
  font-size: 30rpx;
}

.hint-text {
  font-size: 25rpx;
  line-height: 1.6;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.match-shell {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 0 8rpx;
}

.match-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.match-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 107, 0.1);
  color: var(--primary-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.match-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.status-badge.pending {
  background: linear-gradient(135deg, #f4f6f5 0%, #ebefed 100%);
  color: #8d9a95;
}

.status-badge.playing {
  background: linear-gradient(135deg, #eaf4ff 0%, #d8e9ff 100%);
  color: #2d73c8;
}

.status-badge.confirming {
  background: linear-gradient(135deg, #fff8e8 0%, #fff0c6 100%);
  color: #d08711;
}

.status-badge.confirmed {
  background: linear-gradient(135deg, #ecfaf3 0%, #dff4e9 100%);
  color: #0f8f5d;
}

.match-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #143b45 0%, #1b5360 52%, #236b78 100%);
  color: #ffffff;
  box-shadow: var(--shadow-lg);
}

.match-card.playing {
  background: linear-gradient(145deg, #12907f 0%, #1bb687 100%);
}

.match-card.completed {
  background: linear-gradient(145deg, #66757c 0%, #89979d 100%);
}

.match-card.pending {
  background: linear-gradient(145deg, #4e6774 0%, #657f8b 100%);
}

.match-card.confirming {
  background: linear-gradient(145deg, #db861e 0%, #f0a23b 100%);
}

.card-shine {
  position: absolute;
  top: -30%;
  left: -30%;
  width: 60%;
  height: 160%;
  background: radial-gradient(ellipse, rgba(255, 255, 255, 0.16) 0%, transparent 70%);
  pointer-events: none;
}

.match-teams {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.team-info {
  flex: 1;
  padding: 22rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  text-align: center;
}

.team-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.team1-avatar {
  background: linear-gradient(135deg, #536ff3 0%, #6b53c5 100%);
}

.team2-avatar {
  background: linear-gradient(135deg, #eb4f8f 0%, #da3a76 100%);
}

.team-avatar .avatar-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.team-name {
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.team-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.team-members {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.team-level {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
}

.vs-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.vs {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 800;
}

.match-actions {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  display: flex;
  justify-content: center;
}

.score-display {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.16);
}

.score-team {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 800;
}

.score-divider {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.82);
}

.btn-score {
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 44rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #194b57;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.actions {
  padding: 32rpx 0 24rpx;
  display: flex;
  justify-content: center;
}

.btn-ranking {
  min-width: 320rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f69f1 0%, #6149b8 100%);
  color: #ffffff;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 12rpx 24rpx rgba(97, 73, 184, 0.22);
}

.naming-modal {
  position: fixed;
  inset: 0;
  background: rgba(12, 33, 26, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.naming-content {
  width: 620rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 20rpx 48rpx rgba(15, 66, 49, 0.18);
}

.naming-title {
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.naming-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid rgba(18, 69, 51, 0.06);
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  box-sizing: border-box;
}

.naming-actions {
  display: flex;
  gap: 18rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.btn-cancel {
  background: rgba(244, 247, 246, 0.96);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--primary-gradient);
  color: #ffffff;
  box-shadow: var(--shadow-primary);
}
