<view class="grouping-page">
  <view wx:if="{{loading}}" class="loading grouping-loading">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:if="{{!loading && activity}}" class="page-shell grouping-shell">
    <view class="grouping-hero">
      <view class="hero-copy">
        <view class="hero-badge">GROUP STAGE</view>
        <view class="hero-title">分组结果</view>
        <view class="hero-subtitle">{{activity.name}}</view>
      </view>
      <view class="hero-stat-card">
        <text class="stat-num">{{matches.length}}</text>
        <text class="stat-label">场比赛</text>
      </view>
    </view>

    <view wx:if="{{isOrganizer && activity.status === 'grouping'}}" class="section grouping-section start-all-section">
      <button class="btn-start-all" bindtap="startAllMatches">
        <text class="btn-icon">🚀</text>
        <text>开始所有比赛</text>
      </button>
    </view>

    <view class="progress-hint" wx:if="{{activity.status === 'playing'}}">
      <text class="hint-icon">📳</text>
      <text class="hint-text">比赛进行中，已完成 {{completedCount}} / {{matches.length}} 场</text>
    </view>

    <view class="venue-list">
      <block wx:for="{{matches}}" wx:key="_id">
        <view class="match-shell">
          <view class="match-header">
            <view class="match-meta">
              <text class="match-badge">
                <text wx:if="{{item.round === 'group'}}">小组赛</text>
                <text wx:elif="{{item.round === 'challenge'}}">挑战赛</text>
                <text wx:elif="{{item.round === 'final'}}">决赛</text>
              </text>
              <text class="match-title">{{item.venue}}</text>
            </view>
            <view class="status-badge {{item.status}}">
              <text wx:if="{{item.status === 'pending'}}">待开始</text>
              <text wx:elif="{{item.status === 'playing'}}">比赛中</text>
              <text wx:elif="{{item.status === 'confirming'}}">待确认</text>
              <text wx:elif="{{item.status === 'confirmed'}}">已结束</text>
            </view>
          </view>

          <view class="match-card {{item.status === 'confirmed' ? 'completed' : item.status === 'playing' ? 'playing' : item.status === 'confirming' ? 'confirming' : item.status === 'pending' ? 'pending' : ''}}">
            <view class="card-shine"></view>

            <view class="match-teams">
              <view class="team-info" data-teamid="{{item.team1_id}}" bindtap="startNaming">
                <view class="team-avatar team1-avatar">
                  <text class="avatar-text">{{item.team1_name && item.team1_name.length > 0 ? item.team1_name[0] : '?'}}</text>
                </view>
                <text class="team-name">{{item.team1_name || '待命名'}}</text>
                <view class="team-detail" wx:if="{{item.team1_members}}">
                  <text class="team-members">{{item.team1_members}}</text>
                  <text class="team-level">等级 {{item.team1_totalLevel}}</text>
                </view>
              </view>

              <view class="vs-divider">
                <view class="vs-circle">
                  <text class="vs">VS</text>
                </view>
              </view>

              <view class="team-info" data-teamid="{{item.team2_id}}" bindtap="startNaming">
                <view class="team-avatar team2-avatar">
                  <text class="avatar-text">{{item.team2_name && item.team2_name.length > 0 ? item.team2_name[0] : '?'}}</text>
                </view>
                <text class="team-name">{{item.team2_name || '待命名'}}</text>
                <view class="team-detail" wx:if="{{item.team2_members}}">
                  <text class="team-members">{{item.team2_members}}</text>
                  <text class="team-level">等级 {{item.team2_totalLevel}}</text>
                </view>
              </view>
            </view>

            <view class="match-actions">
              <view wx:if="{{item.status === 'confirmed'}}" class="score-display">
                <text class="score-team">{{item.team1_score}}</text>
                <text class="score-divider">:</text>
                <text class="score-team">{{item.team2_score}}</text>
              </view>
              <button
                class="btn-score"
                data-matchid="{{item._id}}"
                bindtap="goToMatchScore"
                wx:else>
                <text class="btn-icon">✍</text>
                <text>记分</text>
              </button>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="actions">
      <button class="btn-ranking" bindtap="goToRanking">
        <text class="btn-icon">🏆</text>
        <text>查看排名</text>
      </button>
    </view>
  </view>

  <view class="naming-modal" wx:if="{{namingTeamId}}" catchtap="cancelNaming">
    <view class="naming-content" catchtap="stopPropagation">
      <text class="naming-title">命名队伍</text>
      <input
        class="naming-input"
        placeholder="请输入队名"
        value="{{teamName}}"
        bindinput="onTeamNameInput"
        maxlength="10"/>
      <view class="naming-actions">
        <button class="btn-cancel" bindtap="cancelNaming">取消</button>
        <button class="btn-confirm" bindtap="confirmTeamName">确认</button>
      </view>
    </view>
  </view>
</view>
