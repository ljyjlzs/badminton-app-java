.create-page {
  min-height: 100vh;
}

.form-hero {
  padding: 18rpx 4rpx 26rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 107, 0.1);
  color: var(--primary-dark);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  font-size: 48rpx;
  line-height: 1.16;
  color: var(--text-primary);
  font-weight: 800;
  margin-bottom: 10rpx;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.form-section {
  border-radius: 30rpx;
  padding: 34rpx 28rpx;
}

.form-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(18, 69, 51, 0.06);
}

.type-toggle {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.type-btn {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid rgba(18, 69, 51, 0.06);
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
}

.type-btn.active {
  background: linear-gradient(135deg, #effbf5 0%, #e5f6ee 100%);
  color: var(--primary-dark);
  border-color: rgba(14, 165, 107, 0.24);
  box-shadow: 0 10rpx 24rpx rgba(17, 181, 116, 0.12);
}

.location-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.location-input {
  flex: 1;
}

.btn-select-location {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 34rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #effbf5 0%, #dff2e8 100%);
  color: var(--primary-dark);
  border: 2rpx solid rgba(14, 165, 107, 0.18);
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.double-picker-row {
  display: flex;
  gap: 18rpx;
}

.picker-item {
  flex: 1;
}

.picker-value {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 54rpx 0 28rpx;
  border-radius: 24rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid transparent;
  color: var(--text-primary);
  font-size: 30rpx;
  position: relative;
  box-sizing: border-box;
}

.picker-value::after {
  content: '▾';
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-light);
  font-size: 24rpx;
}

.player-info {
  display: flex;
  gap: 14rpx;
}

.player-chip {
  flex: 1;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f8fcfa 0%, #f1f6f4 100%);
  border: 1rpx solid rgba(18, 69, 51, 0.05);
}

.player-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.player-value {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.tip-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 30rpx 28rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  margin-bottom: 24rpx;
}

.tip-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 18rpx;
}

.tip-item {
  position: relative;
  padding-left: 20rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.tip-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary-color);
}

.submit-bar {
  padding: 8rpx 0 28rpx;
}

.btn-submit {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 999rpx;
  background: var(--primary-gradient);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  border: none;
  box-shadow: var(--shadow-primary);
}

.btn-submit[disabled] {
  background: #cdd7d2;
  color: rgba(23, 51, 42, 0.48);
  box-shadow: none;
}
