.home-page {
  min-height: 100vh;
}

.login-shell {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.login-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.login-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(12rpx);
}

.login-glow-1 {
  width: 340rpx;
  height: 340rpx;
  top: -80rpx;
  right: -70rpx;
  background: rgba(18, 185, 119, 0.12);
}

.login-glow-2 {
  width: 260rpx;
  height: 260rpx;
  left: -80rpx;
  bottom: 120rpx;
  background: rgba(35, 138, 255, 0.08);
}

.login-line {
  position: absolute;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(14, 165, 107, 0.28), transparent);
  transform: rotate(-18deg);
}

.login-line-1 {
  width: 420rpx;
  top: 180rpx;
  left: -40rpx;
}

.login-line-2 {
  width: 360rpx;
  bottom: 220rpx;
  right: -40rpx;
}

.login-hero {
  position: relative;
  z-index: 1;
  border-radius: 40rpx;
  padding: 52rpx 42rpx 40rpx;
  margin-bottom: 28rpx;
}

.login-kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 28rpx;
}

.login-icon {
  font-size: 124rpx;
  line-height: 1;
  margin-bottom: 22rpx;
}

.login-title {
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #ffffff;
  margin-bottom: 18rpx;
}

.login-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.7;
}

.login-values {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 32rpx;
}

.value-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.login-panel {
  position: relative;
  z-index: 1;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 34rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.panel-copy {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  background: var(--primary-gradient);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: var(--shadow-primary);
}

.btn-login:active {
  opacity: 0.94;
  transform: scale(0.985);
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 120rpx 0;
}

.main-shell {
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(145deg, #103c31 0%, #17513f 56%, #1c6d57 100%);
  border-radius: 38rpx;
  padding: 34rpx 30rpx 28rpx;
  margin-bottom: 28rpx;
  color: #ffffff;
  box-shadow: 0 22rpx 50rpx rgba(16, 60, 49, 0.22);
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  right: -80rpx;
  top: -120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
}

.hero-user {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.avatar-wrap {
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 22rpx;
  position: relative;
  flex-shrink: 0;
}

.avatar-btn {
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.36);
  background: linear-gradient(135deg, #ffe08b 0%, #ffba57 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-placeholder text {
  color: #ffffff;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: rgba(255, 255, 255, 0.66);
  margin-bottom: 10rpx;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
}

.hero-mark {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.4);
  padding-top: 8rpx;
  margin-left: 12rpx;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.hero-stat {
  flex: 1;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.11);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10rpx);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  margin-bottom: 10rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
  color: #ffffff;
}

.announcement-bar {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  position: relative;
  z-index: 1;
}

.announcement-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.announcement-text {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.announcement-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.action-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(17, 69, 52, 0.08);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  display: flex;
  flex-direction: column;
  min-height: 220rpx;
}

.action-item:active {
  transform: scale(0.985);
}

.action-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #eefaf4 0%, #e2f3eb 100%);
  color: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-bottom: 24rpx;
}

.action-title {
  font-size: 30rpx;
  line-height: 1.35;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 10rpx;
}

.action-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-tertiary);
}

.section-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx 26rpx 26rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  margin-bottom: 24rpx;
}

.muted-section {
  background: rgba(250, 252, 251, 0.95);
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.section-caption {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-tertiary);
}

.section-more {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding-top: 6rpx;
  flex-shrink: 0;
}

.activity-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.activity-card {
  background: linear-gradient(135deg, rgba(248, 252, 250, 0.98) 0%, rgba(242, 248, 245, 0.98) 100%);
  border-radius: 26rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(18, 69, 51, 0.06);
}

.activity-card.disabled {
  opacity: 0.88;
}

.activity-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.activity-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.4;
  color: var(--text-primary);
  font-weight: 700;
}

.activity-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  font-size: 24rpx;
  color: var(--text-secondary);
}

.activity-progress-row {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(18, 69, 51, 0.06);
}

.compact-empty {
  padding: 52rpx 24rpx 44rpx;
}

.link {
  color: var(--primary-color);
  font-weight: 600;
}

.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 33, 26, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(12rpx);
}

.picker-content {
  width: 620rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 48rpx rgba(15, 66, 49, 0.18);
  animation: scaleIn 0.24s ease;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.picker-title {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
}

.picker-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-cancel {
  background: rgba(244, 247, 246, 0.96);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--primary-gradient);
  color: #ffffff;
  box-shadow: var(--shadow-primary);
}
