<view class="home-page">
  <view wx:if="{{!isLoggedIn && !loading}}" class="login-shell">
    <view class="login-bg">
      <view class="login-glow login-glow-1"></view>
      <view class="login-glow login-glow-2"></view>
      <view class="login-line login-line-1"></view>
      <view class="login-line login-line-2"></view>
    </view>

    <view class="login-hero card-gradient">
      <view class="login-kicker">BADMINTON MATCHDAY</view>
      <view class="login-icon">🏸</view>
      <view class="login-title">羽毛球报名小程序</view>
      <view class="login-desc">报名、分组、比赛、排名，一套流程顺下来。</view>

      <view class="login-values">
        <view class="value-chip">快速报名</view>
        <view class="value-chip">智能分组</view>
        <view class="value-chip">实时赛程</view>
      </view>
    </view>

    <view class="login-panel card">
      <view class="panel-title">把每场活动安排得更清楚</view>
      <view class="panel-copy">统一管理参赛人、赛程和结果，活动组织更省心。</view>

      <button
        class="btn-login"
        open-type="getUserInfo"
        bindgetuserinfo="onGetUserInfo">
        微信授权登录
      </button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-section">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:if="{{isLoggedIn && !loading}}" class="main-shell">
    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-user">
          <view class="avatar-wrap">
            <button
              class="avatar-btn"
              open-type="chooseAvatar"
              bindchooseavatar="onChooseAvatar">
              <image
                wx:if="{{userInfo.avatar}}"
                class="user-avatar"
                src="{{userInfo.avatar}}"
                mode="aspectFill"></image>
              <view wx:else class="user-avatar avatar-placeholder">
                <text>{{userInfo && (userInfo.nickname || userInfo.name) ? (userInfo.nickname[0] || userInfo.name[0]) : '?'}}</text>
              </view>
            </button>
          </view>

          <view class="hero-copy">
            <view class="hero-kicker">READY TO PLAY</view>
            <text class="hero-name" bindtap="onEditNickname">{{userInfo && userInfo.nickname ? userInfo.nickname : '点击设置昵称'}}</text>
            <text class="hero-subtitle">今天想先创建活动，还是直接去找一场比赛？</text>
          </view>
        </view>

        <view class="hero-mark">MATCH</view>
      </view>

      <view class="hero-stats">
        <view class="hero-stat">
          <text class="stat-label">我创建的</text>
          <text class="stat-value">{{myActivities.length}}</text>
        </view>
        <view class="hero-stat">
          <text class="stat-label">可参加</text>
          <text class="stat-value">{{joinableActivities.length}}</text>
        </view>
        <view class="hero-stat">
          <text class="stat-label">进行中</text>
          <text class="stat-value">{{unavailableActivities.length}}</text>
        </view>
      </view>

      <view class="announcement-bar" bindtap="goToRules">
        <text class="announcement-icon">📢</text>
        <text class="announcement-text">查看比赛规则和积分说明</text>
        <text class="announcement-arrow">›</text>
      </view>
    </view>

    <view class="action-grid">
      <view class="action-item" bindtap="goToCreateActivity">
        <view class="action-icon">+</view>
        <text class="action-title">创建活动</text>
        <text class="action-desc">新建一场报名活动并管理赛程</text>
      </view>

      <view class="action-item" bindtap="goToActivityList" data-tab="search">
        <view class="action-icon">🔎</view>
        <text class="action-title">查找活动</text>
        <text class="action-desc">看看附近有什么比赛正在报名</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view>
          <text class="section-title">我创建的活动</text>
          <text class="section-caption">你负责组织和推进的比赛</text>
        </view>
        <text class="section-more" bindtap="goToActivityList" data-tab="created">查看全部</text>
      </view>

      <view wx:if="{{myActivities.length === 0}}" class="empty-tip compact-empty">
        <text class="empty-icon">🏸</text>
        <text class="empty-text">还没有创建活动</text>
        <text class="empty-desc">点一下创建活动，先把下一场比赛安排起来。</text>
      </view>

      <view wx:else class="activity-stack">
        <view
          wx:for="{{myActivities}}"
          wx:key="_id"
          class="activity-card"
          bindtap="goToActivityDetail"
          data-id="{{item._id}}">
          <view class="activity-card-top">
            <text class="activity-name">{{item.name}}</text>
            <view class="status-badge status-{{item.status}}">
              <text wx:if="{{item.status === 'registering'}}">报名中</text>
              <text wx:elif="{{item.status === 'grouping'}}">分组中</text>
              <text wx:elif="{{item.status === 'playing'}}">比赛中</text>
              <text wx:elif="{{item.status === 'challenge'}}">挑战赛</text>
              <text wx:elif="{{item.status === 'final'}}">决赛</text>
              <text wx:elif="{{item.status === 'finished'}}">已结束</text>
              <text wx:else>{{item.status}}</text>
            </view>
          </view>
          <view class="activity-meta-row">
            <text class="meta-pill">📍 {{item.location}}</text>
            <text class="meta-pill">👥 {{item.current_players || 0}} / {{item.max_players}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view>
          <text class="section-title">可参加的活动</text>
          <text class="section-caption">正在开放报名，适合直接加入</text>
        </view>
        <text class="section-more" bindtap="goToActivityList" data-tab="search">去挑一场</text>
      </view>

      <view wx:if="{{joinableActivities.length === 0}}" class="empty-tip compact-empty">
        <text class="empty-icon">🗓</text>
        <text class="empty-text">暂时没有可参加活动</text>
        <text class="empty-desc">等组织者发布新活动，或者你先自己发起一场。</text>
      </view>

      <view wx:else class="activity-stack">
        <view
          wx:for="{{joinableActivities}}"
          wx:key="_id"
          class="activity-card"
          bindtap="goToActivityDetail"
          data-id="{{item._id}}">
          <view class="activity-card-top">
            <text class="activity-name">{{item.name}}</text>
            <view class="status-badge status-registering">报名中</view>
          </view>
          <view class="activity-meta-row">
            <text class="meta-pill">📍 {{item.location}}</text>
            <text class="meta-pill">👥 {{item.current_players || 0}} / {{item.max_players}}</text>
          </view>
          <view class="activity-progress-row">
            <progress
              percent="{{(item.current_players / item.max_players) * 100}}"
              stroke-width="8"
              active
              activeColor="#0ea56b"
              backgroundColor="#dfe9e5"/>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card muted-section">
      <view class="section-header">
        <view>
          <text class="section-title">暂时不能参加</text>
          <text class="section-caption">这些活动已经开始或进入后续阶段</text>
        </view>
      </view>

      <view wx:if="{{unavailableActivities.length === 0}}" class="empty-tip compact-empty">
        <text class="empty-icon">✅</text>
        <text class="empty-text">当前没有进行中的比赛</text>
        <text class="empty-desc">一旦有活动进入分组或比赛阶段，会在这里显示。</text>
      </view>

      <view wx:else class="activity-stack">
        <view
          wx:for="{{unavailableActivities}}"
          wx:key="_id"
          class="activity-card disabled"
          bindtap="goToActivityDetail"
          data-id="{{item._id}}">
          <view class="activity-card-top">
            <text class="activity-name">{{item.name}}</text>
            <view class="status-badge status-{{item.status}}">
              <text wx:if="{{item.status === 'grouping'}}">分组中</text>
              <text wx:elif="{{item.status === 'playing'}}">比赛中</text>
              <text wx:elif="{{item.status === 'challenge'}}">挑战赛</text>
              <text wx:elif="{{item.status === 'final'}}">决赛</text>
              <text wx:elif="{{item.status === 'finished'}}">已结束</text>
              <text wx:else>{{item.status}}</text>
            </view>
          </view>
          <view class="activity-meta-row">
            <text class="meta-pill">📍 {{item.location}}</text>
            <text class="meta-pill">👥 {{item.current_players || 0}} / {{item.max_players}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showEditDialog}}" class="picker-mask" bindtap="hideEditDialog">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-title">设置昵称</view>

      <view class="form-item">
        <input
          class="form-input"
          placeholder="请输入昵称"
          maxlength="20"
          value="{{editNickname}}"
          bindinput="onEditNicknameInput"/>
      </view>

      <view class="picker-actions">
        <button class="btn-cancel" bindtap="hideEditDialog">取消</button>
        <button class="btn-confirm" bindtap="confirmEdit">确认</button>
      </view>
    </view>
  </view>
</view>
