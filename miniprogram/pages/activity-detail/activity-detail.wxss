.detail-page {
  min-height: 100vh;
}

.detail-loading {
  min-height: 100vh;
}

.detail-shell {
  padding: 24rpx;
}

.overview-card {
  background: linear-gradient(145deg, #f9fffc 0%, #eef7f3 100%);
  border-radius: 34rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(14, 165, 107, 0.12);
}

.overview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.overview-copy {
  flex: 1;
  min-width: 0;
}

.overview-kicker {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: var(--primary-dark);
  margin-bottom: 12rpx;
}

.activity-name {
  font-size: 40rpx;
  line-height: 1.25;
  color: var(--text-primary);
  font-weight: 800;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.overview-item {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(18, 69, 51, 0.05);
}

.overview-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.overview-value {
  display: block;
  font-size: 27rpx;
  line-height: 1.5;
  color: var(--text-primary);
  font-weight: 600;
}

.progress-block {
  padding-top: 6rpx;
}

.progress-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.progress-title {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-value {
  font-size: 24rpx;
  color: var(--primary-dark);
  font-weight: 700;
}

.organizer-tip {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fff7e9 0%, #ffecc2 100%);
  color: #c98517;
  font-size: 24rpx;
  line-height: 1.6;
}

.detail-section {
  background: rgba(255, 255, 255, 0.96);
  padding: 30rpx 26rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  box-shadow: var(--shadow-card);
}

.section {
  background: rgba(255, 255, 255, 0.96);
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.3;
  color: var(--text-primary);
  font-weight: 700;
}

.section-header {
  align-items: flex-start;
  gap: 18rpx;
}

.section-caption {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.section-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(244, 247, 246, 0.95);
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.section-tags {
  display: flex;
  gap: 10rpx;
}

.registration-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.registration-item {
  width: 152rpx;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f7fbf9 0%, #f1f7f4 100%);
  border: 1rpx solid rgba(18, 69, 51, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.registration-item-wrap {
  position: relative;
}

.registration-item-wrap:active .registration-item {
  transform: scale(0.985);
}

.registration-item .avatar-text {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  background: var(--primary-gradient);
}

.reg-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.registration-item .nickname {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.partner-tag {
  font-size: 20rpx;
  color: var(--primary-color);
  margin-top: 4rpx;
}

.compact-empty {
  padding: 48rpx 20rpx;
}

.compact-inline-empty {
  width: 100%;
  padding: 12rpx 0 0;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.joined-tip,
.full-tip,
.cancel-pending-tip,
.pending-cancel-tip,
.start-hint,
.wait-hint {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  font-size: 27rpx;
  line-height: 1.6;
  text-align: center;
}

.joined-tip {
  background: linear-gradient(135deg, #ebfaf2 0%, #def3e8 100%);
  color: var(--primary-dark);
}

.full-tip {
  background: rgba(244, 247, 246, 0.96);
  color: var(--text-tertiary);
}

.cancel-pending-tip,
.pending-cancel-tip,
.wait-hint {
  background: linear-gradient(135deg, #fff6e8 0%, #ffecc4 100%);
  color: #cc8615;
}

.start-hint {
  background: linear-gradient(135deg, #ebfaf2 0%, #def3e8 100%);
  color: var(--primary-dark);
}

.organizer-action {
  margin-top: 8rpx;
}

.organizer-btns {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.organizer-btns .btn-start,
.organizer-btns .btn-delete,
.organizer-btns .btn-finish {
  flex: 1;
  min-width: 220rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #f6a53b 0%, #ee8f1d 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(238, 143, 29, 0.22);
}

.btn-finish {
  background: linear-gradient(135deg, #536ff3 0%, #6b53c5 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(83, 111, 243, 0.2);
}

.btn-delete {
  background: rgba(255, 245, 245, 0.98);
  color: #d64545;
  border: 2rpx solid rgba(214, 69, 69, 0.16);
}

.btn-center {
  display: flex;
  justify-content: center;
}

.btn-center .btn-start,
.btn-center .btn-challenge,
.btn-center .btn-final {
  width: auto;
  min-width: 320rpx;
  padding: 0 56rpx;
}

.btn-challenge,
.btn-final,
.btn-ranking {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  text-align: center;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-challenge {
  background: linear-gradient(135deg, #eb4f8f 0%, #da3a76 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(218, 58, 118, 0.22);
}

.btn-final {
  background: linear-gradient(135deg, #ffad3b 0%, #f28b1e 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(242, 139, 30, 0.22);
}

.section-tag {
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.challenge-tag {
  background: rgba(218, 58, 118, 0.12);
  color: #cf2f6d;
}

.final-tag {
  background: rgba(242, 139, 30, 0.14);
  color: #d57910;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.match-card {
  padding: 30rpx 26rpx;
}

.challenge-match {
  background: linear-gradient(145deg, #a6256a 0%, #d6478b 100%) !important;
}

.final-match {
  background: linear-gradient(145deg, #d47f16 0%, #f4a933 100%) !important;
}

.match-pending {
  border: 2rpx dashed rgba(255, 255, 255, 0.42) !important;
}

.match-playing,
.challenge-match.match-playing,
.final-match.match-playing {
  animation: pulse 1.5s ease-in-out infinite !important;
}

.match-confirming,
.challenge-match.match-confirming,
.final-match.match-confirming {
  animation: blink 1.1s ease-in-out infinite !important;
}

.playing-status {
  background: rgba(255, 255, 255, 0.2) !important;
  color: #ffffff !important;
}

.confirm-status {
  background: rgba(255, 255, 255, 0.16) !important;
  color: #ffffff !important;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 14rpx 30rpx rgba(56, 239, 125, 0.3);
  }
  50% {
    box-shadow: 0 16rpx 40rpx rgba(56, 239, 125, 0.46);
  }
}

@keyframes blink {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.01);
  }
}

.btn-ranking {
  width: 100%;
  background: linear-gradient(135deg, #4f69f1 0%, #6149b8 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(97, 73, 184, 0.2);
}

.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 33, 26, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.picker-content {
  width: 100%;
  padding: 40rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-radius: 36rpx 36rpx 0 0;
}

.picker-title {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
}

.selected-level-tip {
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.level-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.level-item {
  flex: 1 1 calc(33.333% - 14rpx);
  min-width: 160rpx;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid rgba(18, 69, 51, 0.06);
  color: var(--text-secondary);
  text-align: center;
  font-size: 26rpx;
}

.level-item.selected {
  background: var(--primary-gradient);
  color: #ffffff;
  border-color: transparent;
  box-shadow: var(--shadow-primary);
}

.avatar-form-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-change-hint {
  font-size: 22rpx;
  color: var(--primary-color);
  margin-top: 10rpx;
}

.avatar-upload-btn2 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx dashed rgba(18, 69, 51, 0.12);
  padding: 0;
  margin: 0;
}

.avatar-upload-btn2::after {
  border: none;
}

.avatar-placeholder-btn {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
}

.upload-icon {
  font-size: 48rpx;
}

.upload-text {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.partner-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.partner-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid transparent;
}

.partner-item.selected {
  border-color: rgba(14, 165, 107, 0.22);
  background: rgba(231, 247, 239, 0.96);
}

.partner-avatar {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  border-radius: 50%;
  font-size: 22rpx;
  margin-bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--primary-gradient);
}

.partner-name {
  font-size: 24rpx;
  color: var(--text-primary);
}

.partner-level {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.picker-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-cancel {
  background: rgba(244, 247, 246, 0.96);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--primary-gradient);
  color: #ffffff;
  box-shadow: var(--shadow-primary);
}

.btn-cancel-reg {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 245, 0.98);
  color: #d64545;
  border: 2rpx solid rgba(214, 69, 69, 0.16);
  font-size: 30rpx;
  font-weight: 700;
}

.cancel-request-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
  background: rgba(255, 243, 224, 0.96);
  color: #c98517;
  font-weight: 700;
}

.cancel-request-tag::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #d58c1b;
}

.registration-item-wrap.has-pending .registration-item {
  background: linear-gradient(135deg, #fffaf1 0%, #fff3df 100%);
  border-color: rgba(213, 140, 27, 0.16);
  box-shadow: 0 10rpx 20rpx rgba(213, 140, 27, 0.08);
}

.registration-item-wrap.has-pending .registration-item::after {
  content: '待处理';
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(213, 140, 27, 0.12);
  color: #c98517;
  font-size: 18rpx;
  font-weight: 700;
}

.registration-item {
  position: relative;
}

/* 取消报名审批弹窗 */
.cancel-modal-content {
  width: 580rpx;
  background: var(--surface-card, #ffffff);
  border-radius: var(--radius-xl, 28rpx);
  padding: 48rpx 40rpx 36rpx;
  box-shadow: var(--shadow-lg, 0 12rpx 40rpx rgba(0,0,0,0.12));
  text-align: center;
}

.cancel-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary, #12332b);
  margin-bottom: 32rpx;
}

.cancel-modal-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.cancel-modal-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  background: var(--primary-gradient, linear-gradient(135deg, #0ea56b, #0bc278));
}

.cancel-modal-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.cancel-modal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #12332b);
}

.cancel-modal-level {
  font-size: 24rpx;
  color: var(--text-tertiary, #8d9a95);
  margin-top: 4rpx;
}

.cancel-modal-tip {
  font-size: 26rpx;
  color: var(--text-secondary, #4a5e56);
  margin-bottom: 36rpx;
  line-height: 1.6;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(244, 247, 246, 0.96);
}

.cancel-modal-btns {
  display: flex;
  gap: 20rpx;
}

.cancel-modal-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: var(--radius-full, 999rpx);
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  padding: 0;
  min-height: 84rpx;
  box-sizing: border-box;
}

.cancel-modal-btn.reject {
  background: var(--bg-gray, #f0f5f3);
  color: var(--text-secondary, #4a5e56);
  border: 1rpx solid var(--border-light, rgba(18,69,51,0.08));
}

.cancel-modal-btn.reject:active {
  transform: scale(0.985);
}

.cancel-modal-btn.approve {
  background: var(--primary-gradient, linear-gradient(135deg, #0ea56b, #0bc278));
  color: var(--text-inverse, #ffffff);
  box-shadow: var(--shadow-primary, 0 6rpx 16rpx rgba(14,165,107,0.28));
}

.cancel-modal-btn.approve:active {
  transform: scale(0.985);
}
