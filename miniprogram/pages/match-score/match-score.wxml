<view class="score-page">
  <view wx:if="{{loading}}" class="loading score-loading">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:if="{{!loading && match}}" class="score-shell">
    <view class="score-hero">
      <view class="hero-left">
        <text class="hero-title">
          <text wx:if="{{match.round === 'group'}}">场地 {{match.venue}}</text>
          <text wx:elif="{{match.round === 'challenge'}}">挑战赛</text>
          <text wx:elif="{{match.round === 'final'}}">决赛</text>
        </text>
        <text class="hero-subtitle">
          {{match.round === 'group' ? '小组赛' : match.round === 'challenge' ? '挑战赛（胜者 +10 分）' : '决赛（胜者 +15 分）'}}
        </text>
      </view>
      <view class="status-badge score-status {{match.status}}">
        <text wx:if="{{match.status === 'pending'}}">待开始</text>
        <text wx:elif="{{match.status === 'playing'}}">比赛中</text>
        <text wx:elif="{{match.status === 'confirming'}}">待确认</text>
        <text wx:elif="{{match.status === 'confirmed'}}">已结束</text>
      </view>
    </view>

    <view class="score-board">
      <view class="team-section team1">
        <view class="score-team-name">{{team1 && team1.name ? team1.name : '队伍1'}}</view>
        <view class="score-team-members">
          <text wx:for="{{team1 && team1.members ? team1.members : []}}" wx:key="*this">{{item && item.nickname ? item.nickname : '未知'}}{{index < (team1.members.length - 1) ? ' / ' : ''}}</text>
        </view>
      </view>

      <view class="score-section">
        <view class="score-display">
          <text class="score-num {{team1Score > team2Score ? 'winner' : ''}}">{{team1Score || '-'}}</text>
          <text class="score-divider">:</text>
          <text class="score-num {{team2Score > team1Score ? 'winner' : ''}}">{{team2Score || '-'}}</text>
        </view>

        <view wx:if="{{match && match.status === 'confirmed'}}" class="confirmed-hint">
          比赛已结束
        </view>
      </view>

      <view class="team-section team2">
        <view class="score-team-name">{{team2 && team2.name ? team2.name : '队伍2'}}</view>
        <view class="score-team-members">
          <text wx:for="{{team2 && team2.members ? team2.members : []}}" wx:key="*this">{{item && item.nickname ? item.nickname : '未知'}}{{index < (team2.members.length - 1) ? ' / ' : ''}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{(isOrganizer || isScorer) && match.status !== 'confirmed'}}" class="input-section">
      <view class="input-title">录入比分</view>

      <view class="score-inputs">
        <view class="input-group">
          <text class="input-label">{{team1.name || '队伍1'}}</text>
          <view class="score-input-wrapper">
            <input
              type="number"
              class="score-input"
              value="{{team1Score}}"
              bindinput="onTeam1ScoreInput"
              maxlength="2"/>
            <picker bindchange="onTeam1ScoreChange" value="{{team1Score}}" range="{{scoreRange}}">
              <view class="score-picker-btn">▾</view>
            </picker>
          </view>
        </view>

        <text class="input-vs">VS</text>

        <view class="input-group">
          <text class="input-label">{{team2.name || '队伍2'}}</text>
          <view class="score-input-wrapper">
            <input
              type="number"
              class="score-input"
              value="{{team2Score}}"
              bindinput="onTeam2ScoreInput"
              maxlength="2"/>
            <picker bindchange="onTeam2ScoreChange" value="{{team2Score}}" range="{{scoreRange}}">
              <view class="score-picker-btn">▾</view>
            </picker>
          </view>
        </view>
      </view>

      <button
        class="btn-submit"
        bindtap="submitScore"
        disabled="{{confirming}}">
        {{confirming ? '提交中...' : '提交比分'}}
      </button>
    </view>

    <view wx:if="{{match.status === 'confirmed'}}" class="finished-section">
      <view class="result-text">
        <text wx:if="{{team1Score > team2Score}}">{{team1.name}} 获胜</text>
        <text wx:else>{{team2.name}} 获胜</text>
      </view>

      <view class="finished-actions">
        <button wx:if="{{isOrganizer || isScorer}}" class="btn-modify" bindtap="modifyScore">修改比分</button>
        <button class="btn-back" bindtap="goBack">返回活动</button>
      </view>
    </view>
  </view>
</view>
