.score-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #10252e 0%, #173945 100%);
}

.score-loading {
  min-height: 100vh;
  color: rgba(255, 255, 255, 0.82);
}

.score-shell {
  padding: 24rpx;
}

.score-hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.score-status.pending {
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
}

.score-status.playing {
  background: rgba(56, 239, 125, 0.14);
  color: #7bf0a4;
}

.score-status.confirming {
  background: rgba(255, 195, 84, 0.16);
  color: #ffd485;
}

.score-status.confirmed {
  background: rgba(14, 165, 107, 0.18);
  color: #7de3b7;
}

.score-board {
  padding: 34rpx 28rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 44rpx rgba(4, 15, 20, 0.22);
  backdrop-filter: blur(8rpx);
  margin-bottom: 24rpx;
}

.team-section {
  text-align: center;
}

.score-team-name {
  font-size: 34rpx;
  line-height: 1.25;
  color: #ffffff;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.score-team-members {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.7);
}

.score-section {
  padding: 30rpx 0;
}

.score-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.score-num {
  min-width: 180rpx;
  text-align: center;
  font-size: 148rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.28);
  font-weight: 900;
  text-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.24);
}

.score-num.winner {
  color: #8af0bb;
  transform: scale(1.08);
  text-shadow: 0 0 36rpx rgba(14, 165, 107, 0.34);
}

.score-divider {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 300;
}

.confirmed-hint {
  margin-top: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8af0bb;
  font-weight: 600;
}

.input-section,
.finished-section {
  padding: 30rpx 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.input-title {
  text-align: center;
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 24rpx;
}

.score-inputs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input-label {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.score-input-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.score-input {
  width: 120rpx;
  height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 2rpx solid rgba(18, 69, 51, 0.06);
  color: var(--text-primary);
  font-size: 44rpx;
  font-weight: 800;
}

.score-picker-btn {
  width: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(244, 247, 246, 0.96);
  color: var(--primary-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.input-vs {
  font-size: 30rpx;
  color: var(--text-tertiary);
  font-weight: 800;
}

.btn-submit {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  background: var(--primary-gradient);
  color: #ffffff;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--shadow-primary);
}

.result-text {
  text-align: center;
  font-size: 38rpx;
  line-height: 1.4;
  color: var(--primary-dark);
  font-weight: 800;
  margin-bottom: 28rpx;
}

.finished-actions {
  display: flex;
  gap: 16rpx;
}

.btn-modify,
.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  border: none;
}

.btn-modify {
  background: rgba(231, 247, 239, 0.96);
  color: var(--primary-dark);
  border: 2rpx solid rgba(14, 165, 107, 0.18);
}

.btn-back {
  background: rgba(244, 247, 246, 0.96);
  color: var(--text-secondary);
}
