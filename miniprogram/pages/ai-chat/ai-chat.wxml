<!--pages/ai-chat/ai-chat.wxml-->
<view class="container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="top-bar-title">AI 助手</view>
    <view class="new-chat-btn" bindtap="clearHistory">新对话</view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="msg-list"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation>
    <view wx:if="{{loadingHistory}}" class="loading-tip">加载历史消息...</view>
    <view wx:if="{{!loadingHistory && messages.length === 0}}" class="empty-tip">
      <text class="empty-icon">🤖</text>
      <text class="empty-text">你好！我是羽毛球助手，可以帮你查看活动、分析数据，也可以帮你创建活动、报名活动等。试试问我问题吧！</text>
    </view>

    <view wx:for="{{messages}}" wx:key="_id" id="msg-{{index}}" class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}">
      <!-- 普通消息气泡 -->
      <view wx:if="{{item.displayContent}}" class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
        <text class="msg-text" user-select>{{item.displayContent}}</text>
      </view>

      <!-- 活动选择卡片 -->
      <view wx:if="{{item.hasSelect}}" class="select-card">
        <view class="select-card-header">
          <text class="select-icon">🏸</text>
          <text class="select-title">请选择要报名的活动</text>
        </view>
        <view class="select-list">
          <view
            wx:for="{{item.selectOptions}}"
            wx:for-item="activity"
            wx:key="id"
            class="select-item"
            data-activity="{{activity}}"
            bindtap="onSelectActivity">
            <view class="select-item-name">{{activity.name}}</view>
            <view class="select-item-meta">
              <text class="select-item-time">{{activity.time}}</text>
              <text class="select-item-location">{{activity.location}}</text>
            </view>
            <view wx:if="{{activity.organizer}}" class="select-item-organizer">组织者: {{activity.organizer}}</view>
          </view>
        </view>
      </view>

      <!-- 操作确认卡片 -->
      <view wx:if="{{item.hasAction}}" class="action-card action-card-{{item.actionStatus}}">
        <!-- 卡片头部 -->
        <view class="action-card-header">
          <text class="action-icon">⚡</text>
          <text class="action-title">{{item.actionData.confirm_text || 'AI 操作请求'}}</text>
        </view>

        <!-- 操作参数详情 -->
        <view class="action-params" wx:if="{{item.actionStatus === 'pending'}}">
          <view wx:if="{{item.actionData.action === 'create_activity'}}">
            <view class="param-row"><text class="param-label">名称</text><text class="param-value">{{item.actionData.params.name}}</text></view>
            <view class="param-row"><text class="param-label">时间</text><text class="param-value">{{item.actionData.params.time}}</text></view>
            <view class="param-row"><text class="param-label">地点</text><text class="param-value">{{item.actionData.params.location}}</text></view>
            <view class="param-row"><text class="param-label">类型</text><text class="param-value">{{item.actionData.params.type === 'singles' ? '单打' : (item.actionData.params.type === 'fixed-doubles' ? '双打固搭' : '双打轮换')}}</text></view>
          </view>
          <view wx:elif="{{item.actionData.action === 'join_activity'}}">
            <view class="param-row"><text class="param-label">活动</text><text class="param-value">{{item.actionData.params.activityName}}</text></view>
          </view>
          <view wx:elif="{{item.actionData.action === 'cancel_registration'}}">
            <view class="param-row"><text class="param-label">活动</text><text class="param-value">{{item.actionData.params.activityName}}</text></view>
          </view>
        </view>

        <!-- 执行中 -->
        <view wx:if="{{item.actionStatus === 'executing'}}" class="action-status-row">
          <text class="action-status-icon">⏳</text>
          <text class="action-status-text">执行中...</text>
        </view>

        <!-- 成功 -->
        <view wx:if="{{item.actionStatus === 'success'}}" class="action-status-row action-status-success">
          <text class="action-status-icon">✅</text>
          <text class="action-status-text">{{item.actionResultText || '操作成功'}}</text>
        </view>

        <!-- 失败 -->
        <view wx:if="{{item.actionStatus === 'error'}}" class="action-status-row action-status-error">
          <text class="action-status-icon">❌</text>
          <text class="action-status-text">{{item.actionResultText || '操作失败'}}</text>
        </view>

        <!-- 已取消 -->
        <view wx:if="{{item.actionStatus === 'cancelled'}}" class="action-status-row action-status-cancelled">
          <text class="action-status-icon">🚫</text>
          <text class="action-status-text">操作已取消</text>
        </view>

        <!-- 确认/取消按钮（仅 pending 状态显示）-->
        <view wx:if="{{item.actionStatus === 'pending'}}" class="action-btns">
          <view class="action-btn-cancel" bindtap="onCancelAction" data-index="{{index}}">取消</view>
          <view class="action-btn-confirm" bindtap="onConfirmAction" data-index="{{index}}">确认执行</view>
        </view>
      </view>

      <view class="msg-time">{{item.timeStr}}</view>
    </view>

    <view wx:if="{{loading}}" class="loading-tip">AI 思考中...</view>
    <view id="msg-bottom-" style="height:1rpx;"></view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="input-bar">
    <input
      class="msg-input"
      placeholder="输入消息..."
      value="{{inputValue}}"
      bindinput="onInput"
      bindconfirm="sendMessage"
      confirm-type="send"
      disabled="{{loading}}"
    />
    <button class="send-btn {{loading || !inputValue ? 'disabled' : ''}}" bindtap="sendMessage" disabled="{{loading || !inputValue}}">发送</button>
  </view>
</view>
