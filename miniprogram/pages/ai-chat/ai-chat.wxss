/* pages/ai-chat/ai-chat.wxss */

/* ============ 整体容器 ============ */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent; /* 继承 app.wxss 的渐变背景 */
  padding: 0;
}

/* ============ 顶部栏 ============ */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: var(--primary-gradient-strong);
  color: var(--text-inverse);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  box-shadow: var(--shadow-md);
}

.top-bar-title {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.new-chat-btn {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: var(--radius-full);
  backdrop-filter: blur(8rpx);
  background: rgba(255, 255, 255, 0.1);
  font-weight: 500;
}

/* ============ 空状态 ============ */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
  opacity: 0.45;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.8;
}

/* ============ 消息列表 ============ */
.msg-list {
  flex: 1;
  height: 0;
  padding: 28rpx 24rpx 16rpx;
  box-sizing: border-box;
}

.loading-tip {
  text-align: center;
  color: var(--text-light);
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* ============ 消息行 ============ */
.msg-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 28rpx;
  animation: slideUp 0.3s ease;
}

.msg-right {
  align-items: flex-end;
}

.msg-left {
  align-items: flex-start;
}

/* ============ 消息气泡 ============ */
.msg-bubble {
  max-width: 72%;
  padding: 22rpx 30rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.bubble-user {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  border-bottom-right-radius: var(--radius-xs);
  box-shadow: var(--shadow-primary);
}

.bubble-ai {
  background: var(--surface-card);
  color: var(--text-primary);
  border-bottom-left-radius: var(--radius-xs);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-light);
  backdrop-filter: blur(12rpx);
}

.msg-text {
  user-select: text;
}

.msg-time {
  font-size: 20rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  padding: 0 8rpx;
}

/* ============ 活动选择卡片 ============ */
.select-card {
  width: 90%;
  margin: 10rpx 0;
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 28rpx 26rpx;
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--border-light);
  border-left: 8rpx solid #2386e0;
  backdrop-filter: blur(12rpx);
  animation: slideUp 0.32s ease;
}

.select-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.select-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.select-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.select-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.select-item {
  background: linear-gradient(135deg, #fbfdfc 0%, #f4f8f6 100%);
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid var(--border-light);
  transition: all 0.2s ease;
}

.select-item:active {
  border-color: var(--primary-color);
  background: rgba(14, 165, 107, 0.05);
  transform: scale(0.98);
}

.select-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.select-item-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.select-item-time,
.select-item-location {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.select-item-organizer {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ============ 操作确认卡片 ============ */
.action-card {
  width: 90%;
  margin: 10rpx 0;
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 28rpx 26rpx;
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--border-light);
  border-left: 8rpx solid var(--primary-color);
  backdrop-filter: blur(12rpx);
  animation: slideUp 0.32s ease;
}

/* 不同状态边框 */
.action-card-success {
  border-left-color: #0ea56b;
}

.action-card-error {
  border-left-color: #d64545;
}

.action-card-cancelled {
  border-left-color: var(--text-light);
  opacity: 0.72;
}

.action-card-executing {
  border-left-color: #2386e0;
}

/* 卡片头部 */
.action-card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  line-height: 1.4;
  padding-top: 2rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  line-height: 1.5;
}

/* 参数详情 */
.action-params {
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #fbfdfc 0%, #f4f8f6 100%);
  border-radius: 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid var(--border-light);
}

.param-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.param-row:last-child {
  margin-bottom: 0;
}

.param-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 80rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.param-value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
  line-height: 1.6;
}

/* 状态行 */
.action-status-row {
  display: flex;
  align-items: center;
  padding: 16rpx 2rpx;
  border-radius: 18rpx;
  background: rgba(244, 247, 246, 0.72);
}

.action-status-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  margin-left: 12rpx;
}

.action-status-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
  line-height: 1.6;
}

.action-status-success .action-status-text {
  color: #0ea56b;
  font-weight: 600;
}

.action-status-success {
  background: rgba(231, 247, 239, 0.9);
}

.action-status-error .action-status-text {
  color: #d64545;
  font-weight: 500;
}

.action-status-error {
  background: rgba(255, 241, 241, 0.9);
}

.action-status-cancelled .action-status-text {
  color: var(--text-light);
}

.action-status-cancelled {
  background: rgba(244, 247, 246, 0.88);
}

/* 确认/取消按钮 */
.action-btns {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.action-btn-cancel {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(244, 247, 246, 0.96);
  border: 1rpx solid var(--border-light);
}

.action-btn-cancel:active {
  opacity: 0.88;
  transform: scale(0.985);
}

.action-btn-confirm {
  flex: 2;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-inverse);
  background: var(--primary-gradient);
  border: none;
  box-shadow: var(--shadow-primary);
}

.action-btn-confirm:active {
  opacity: 0.94;
  transform: scale(0.985);
}

/* ============ 底部输入栏 ============ */
.input-bar {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: var(--surface-card-strong);
  border-top: 1rpx solid var(--border-light);
  gap: 16rpx;
  box-shadow: 0 -6rpx 20rpx rgba(17, 69, 52, 0.04);
}

.msg-input {
  flex: 1;
  height: 76rpx;
  padding: 0 28rpx;
  background: var(--bg-gray);
  border-radius: var(--radius-full);
  font-size: 28rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.msg-input:focus {
  border-color: var(--border-strong);
  background: var(--bg-white);
  box-shadow: 0 0 0 6rpx rgba(14, 165, 107, 0.08);
}

.send-btn {
  min-width: 120rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  font-size: 28rpx;
  font-weight: 700;
  border-radius: var(--radius-full);
  border: none;
  padding: 0 28rpx;
  box-shadow: var(--shadow-primary);
}

.send-btn:active {
  opacity: 0.94;
  transform: scale(0.985);
}

.send-btn.disabled {
  background: #cdd7d2;
  color: rgba(23, 51, 42, 0.48);
  box-shadow: none;
}
