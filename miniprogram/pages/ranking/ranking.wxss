.ranking-page {
  min-height: 100vh;
}

.ranking-loading {
  min-height: 100vh;
}

.ranking-hero {
  padding: 24rpx 24rpx 18rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 107, 0.1);
  color: var(--primary-dark);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  font-size: 48rpx;
  line-height: 1.18;
  color: var(--text-primary);
  font-weight: 800;
  margin-bottom: 10rpx;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.content {
  padding-bottom: 30rpx;
}

.tab-shell {
  padding: 0 24rpx 18rpx;
}

.tab-header {
  display: flex;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  box-shadow: 0 12rpx 28rpx rgba(17, 69, 52, 0.05);
}

.tab-item {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(135deg, #effaf4 0%, #e4f5ec 100%);
  color: var(--primary-dark);
}

.ranking-section {
  margin: 0 24rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(18, 69, 51, 0.06);
  box-shadow: var(--shadow-card);
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(247, 250, 249, 0.98);
  border: 1rpx solid rgba(18, 69, 51, 0.05);
  animation: slideUp 0.32s ease backwards;
}

.ranking-item:nth-child(1) { animation-delay: 0.05s; }
.ranking-item:nth-child(2) { animation-delay: 0.1s; }
.ranking-item:nth-child(3) { animation-delay: 0.15s; }
.ranking-item:nth-child(4) { animation-delay: 0.2s; }
.ranking-item:nth-child(5) { animation-delay: 0.25s; }

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ranking-item.gold {
  background: linear-gradient(135deg, #fffaf0 0%, #fff2cf 100%);
  border: 1rpx solid rgba(232, 186, 54, 0.42);
  box-shadow: 0 12rpx 24rpx rgba(232, 186, 54, 0.12);
}

.ranking-item.silver {
  background: linear-gradient(135deg, #fbfbfb 0%, #eef1f3 100%);
  border: 1rpx solid rgba(174, 183, 192, 0.38);
}

.ranking-item.bronze {
  background: linear-gradient(135deg, #fff8f4 0%, #fbe6d6 100%);
  border: 1rpx solid rgba(205, 127, 50, 0.28);
}

.rank-badge {
  width: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.rank-icon {
  font-size: 44rpx;
  line-height: 1;
}

.rank-num {
  font-size: 32rpx;
  color: var(--text-tertiary);
  font-weight: 700;
}

.ranking-avatar,
.avatar-text {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  margin: 0 18rpx;
  flex-shrink: 0;
}

.ranking-avatar {
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
}

.avatar-text {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
  background: var(--primary-gradient);
}

.ranking-item.gold .avatar-text {
  background: linear-gradient(135deg, #e9be45 0%, #d8a72a 100%);
}

.ranking-item.silver .avatar-text {
  background: linear-gradient(135deg, #b9c2ca 0%, #95a3b0 100%);
}

.ranking-item.bronze .avatar-text {
  background: linear-gradient(135deg, #dc9961 0%, #c97b37 100%);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 31rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-level {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 247, 246, 0.96);
  font-size: 22rpx;
  color: var(--text-secondary);
}

.score-info {
  min-width: 170rpx;
  text-align: right;
  flex-shrink: 0;
}

.total-score {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 800;
  color: var(--text-primary);
}

.total-score.positive,
.score-num.positive {
  color: var(--primary-dark);
}

.total-score.negative,
.score-num.negative {
  color: #d64545;
}

.score-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-tertiary);
}

.team-item {
  position: relative;
  padding-right: 160rpx;
}

.team-info-full {
  flex: 1;
  min-width: 0;
}

.team-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 14rpx;
}

.team-members-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.team-member {
  display: flex;
  align-items: center;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(244, 247, 246, 0.96);
  border: 1rpx solid rgba(18, 69, 51, 0.05);
}

.member-avatar-img,
.member-avatar-text {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.member-avatar-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  background: var(--primary-gradient);
}

.member-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.team-score {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  text-align: right;
}

.score-num {
  display: block;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 800;
  color: var(--text-primary);
}

.score-unit {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-tertiary);
}
