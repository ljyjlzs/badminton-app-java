/* pages/rules/rules.wxss */

.rules-page {
  min-height: 100vh;
  background: transparent;
  padding-bottom: 40rpx;
}

/* 顶部 Hero */
.rules-hero {
  background: var(--primary-gradient-strong);
  padding: 48rpx 32rpx 40rpx;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  color: var(--text-inverse);
  text-align: center;
}

.hero-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 加载中 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-light);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 内容区域 */
.rules-content {
  padding: 24rpx;
}

/* Tab 切换 */
.tab-shell {
  margin-bottom: 24rpx;
}

.tab-header {
  display: flex;
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-light);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.tab-item.active {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  box-shadow: var(--shadow-primary);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 规则卡片 */
.rule-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-card {
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-light);
}

.rule-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.rule-card-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.rule-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-bullet {
  color: var(--primary-color);
  font-weight: 700;
  margin-right: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.rule-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
