.score-slider {
  padding: 20rpx;
}

.score-slider.disabled {
  opacity: 0.6;
}

.quick-scores {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.quick-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #666;
}

.quick-btn.active {
  background-color: #07c160;
  color: #fff;
}

.quick-btn.disabled {
  background-color: #e0e0e0;
  color: #999;
}

.slider-section {
  padding: 20rpx 0;
}

.score-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.score-input {
  width: 160rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.score-input.disabled {
  color: #999;
}

.score-label {
  font-size: 36rpx;
  color: #666;
  margin-left: 20rpx;
}

.score-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 28rpx;
}

.hint-win {
  color: #07c160;
}

.hint-good {
  color: #ff9800;
}

.hint-normal {
  color: #999;
}
